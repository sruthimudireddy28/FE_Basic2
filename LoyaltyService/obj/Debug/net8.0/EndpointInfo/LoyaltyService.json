{
  "openapi": "3.0.1",
  "info": {
    "title": "Loyalty Service API",
    "description": "Microservice for managing loyalty points and rewards",
    "version": "v1"
  },
  "paths": {
    "/api/Loyalty/account": {
      "get": {
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/account/{userId}": {
      "get": {
        "tags": [
          "Loyalty"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/earn": {
      "post": {
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EarnPointsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EarnPointsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EarnPointsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/redeem": {
      "post": {
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemPointsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemPointsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemPointsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/history": {
      "get": {
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/redemptions": {
      "get": {
        "tags": [
          "Loyalty"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/calculate-discount": {
      "post": {
        "tags": [
          "Loyalty"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateDiscountDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateDiscountDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CalculateDiscountDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Loyalty/bonus/{userId}": {
      "post": {
        "tags": [
          "Loyalty"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddBonusPointsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddBonusPointsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddBonusPointsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddBonusPointsDto": {
        "type": "object",
        "properties": {
          "points": {
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CalculateDiscountDto": {
        "type": "object",
        "properties": {
          "pointsToUse": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "EarnPointsDto": {
        "type": "object",
        "properties": {
          "bookingId": {
            "type": "integer",
            "format": "int32"
          },
          "bookingAmount": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "RedeemPointsDto": {
        "type": "object",
        "properties": {
          "pointsToRedeem": {
            "type": "integer",
            "format": "int32"
          },
          "bookingId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. Enter 'Bearer' [space] and then your token",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}